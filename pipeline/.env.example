# ═══════════════════════════════════════════════════════════
# VN30 Pipeline — Environment Variables
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────────
# Option A: Local Docker (TimescaleDB)
PIPELINE_DB_URL=postgresql+asyncpg://vn30:vn30_dev_only@localhost:5432/vn30_pipeline
PIPELINE_DB_URL_SYNC=postgresql://vn30:vn30_dev_only@localhost:5432/vn30_pipeline

# Option B: Supabase (cloud, không cần Docker)
#   Lưu ý: Supabase không hỗ trợ TimescaleDB extension.
#   Schema đã được thiết kế để chạy trên PostgreSQL thường.
#   1. Tạo project qua Supabase MCP hoặc dashboard
#   2. Dùng connection string từ Project Settings → Database
# PIPELINE_DB_URL=postgresql+asyncpg://postgres.nqgmfsqnueuzxxsjwrvx:YOUR_PASS@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
# PIPELINE_DB_URL_SYNC=postgresql://postgres.nqgmfsqnueuzxxsjwrvx:YOUR_PASS@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ── Redis ───────────────────────────────────────────────────
# Option A: Local Docker (redis:7-alpine)
PIPELINE_REDIS_URL=redis://localhost:6379/0

# Option B: Upstash Redis (cloud TCP, không dùng HTTP API)
#   1. Tạo database tại https://console.upstash.com → Redis
#   2. Chọn "Global" region, copy REST URL
#   3. Chuyển redis:// → rediss://, thêm password
# PIPELINE_REDIS_URL=rediss://default:YOUR_PASS@us1-xxx.upstash.io:6379/0

# ── MCP servers ─────────────────────────────────────────────
PIPELINE_FIREANT_MCP_DIR=../mcp-server
PIPELINE_DNSE_MCP_DIR=../mcp-server-dnse

# ── DNSE Trading ──────────────────────────────────────────────
PIPELINE_DNSE_EMAIL=your-email@example.com
PIPELINE_DNSE_ACCOUNT_NO=your-account-number

# ── Telegram ──────────────────────────────────────────────────
PIPELINE_TELEGRAM_BOT_TOKEN=
PIPELINE_TELEGRAM_CHAT_ID=

# ── Risk Management ──────────────────────────────────────────
# PIPELINE_MAX_DRAWDOWN_PCT=15.0
# PIPELINE_BLACK_SWAN_THRESHOLD_PCT=-5.0
# PIPELINE_MAX_SECTOR_FINANCE_PCT=40.0
# PIPELINE_MAX_SECTOR_REALESTATE_PCT=20.0
# PIPELINE_MAX_SINGLE_POSITION_PCT=10.0
# PIPELINE_MIN_CASH_PCT=25.0

# ── Human-in-loop ────────────────────────────────────────────
# PIPELINE_APPROVAL_REQUIRED=true
# PIPELINE_APPROVAL_TIMEOUT_MINUTES=60

# ── Logging ─────────────────────────────────────────────────
PIPELINE_LOG_LEVEL=INFO
